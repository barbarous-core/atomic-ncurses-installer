  "systemd": {
    "units": [
      {
        "name": "barbarous-provisioning.service",
        "enabled": true,
        "contents": "[Unit]\nDescription=Barbarous First Boot Provisioning\nAfter=network-online.target\nWants=network-online.target\nConditionFirstBoot=yes\n\n[Service]\nType=oneshot\nExecStart=/usr/bin/localectl set-x11-keymap us\nExecStart=/usr/bin/rpm-ostree install -y /var/lib/barbarous/rpms/*.rpm\nExecStart=/usr/bin/echo 'Dotfiles installation enabled'\nExecStart=/usr/bin/cp -r /var/lib/barbarous/bins/* /usr/local/bin/\nExecStart=/usr/bin/chmod +x /usr/local/bin/*\nExecStart=/usr/bin/systemctl reboot\nStandardOutput=journal+console\nRemainAfterExit=yes\n\n[Install]\nWantedBy=multi-user.target"
      }
    ]
  }
}
